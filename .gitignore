# -----------------------------------------------
# Project-specific
# -----------------------------------------------

# Virtual environment archives — never commit these.
# The venv is created automatically by start_backend.bat.
backend/venv.rar
backend/venv/

# Raw downloaded datasets — re-generated by download_data.py.
# Safe to commit if you want the repo to work out of the box
# without running the download step. Comment out to exclude them.
# backend/data/raw/

# Processed combined dataset — re-generated by preprocess_data.py.
# backend/data/processed/

# Trained model artefacts — re-generated by train_model.py.
# Large binary files; exclude if you want a lightweight repo.
# backend/models/*.pkl
# backend/models/*.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
